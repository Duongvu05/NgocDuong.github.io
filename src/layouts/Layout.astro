---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Duong Ngoc Vu — AI Researcher',
  description = 'Undergraduate Researcher at Business AI Lab, NEU. Research on AI for Healthcare and Fraud Detection.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔬</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
  </head>
  <body class="bg-[#020617] text-slate-100 font-sans antialiased overflow-x-hidden">
    <!-- Global starfield background -->
    <canvas id="starfield-global" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index:0;"></canvas>
    <!-- Content above starfield -->
    <div class="relative" style="z-index:1;">
      <slot />
    </div>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" is:inline></script>
    <script is:inline>
      // Force reload when restored from bfcache so styles always load correctly
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) window.location.reload();
      });

      AOS.init({ duration: 650, easing: 'ease-out-cubic', once: true, offset: 60 });

      // Global starfield + constellation + meteors
      (function () {
        const canvas = document.getElementById('starfield-global');
        const ctx = canvas.getContext('2d');
        let W, H, stars = [], meteors = [];
        const CONN_DIST = 110;

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }

        function initStars() {
          stars = [];
          const count = Math.floor((W * H) / 3800);
          for (let i = 0; i < count; i++) {
            stars.push({
              x: Math.random() * W,
              y: Math.random() * H,
              r: Math.random() * 1.2 + 0.15,
              phase: Math.random() * Math.PI * 2,
              speed: Math.random() * 0.006 + 0.002,
              color: Math.random() > 0.8 ? '#bfdbfe' : (Math.random() > 0.5 ? '#e2e8f0' : '#93c5fd'),
            });
          }
        }

        function spawnMeteor() {
          const fromTop = Math.random() > 0.3;
          meteors.push({
            x: fromTop ? Math.random() * W * 0.8 : W + 10,
            y: fromTop ? -10 : Math.random() * H * 0.4,
            vx: -(4 + Math.random() * 6),
            vy:   3 + Math.random() * 5,
            len: 80 + Math.random() * 140,
            life: 1,
            decay: 0.012 + Math.random() * 0.016,
            blue: Math.random() > 0.5,
          });
        }

        let frame = 0;
        function draw() {
          ctx.clearRect(0, 0, W, H);
          frame += 0.016;

          // Stars
          for (const s of stars) {
            const a = 0.12 + 0.6 * (0.5 + 0.5 * Math.sin(frame * s.speed * 60 + s.phase));
            ctx.globalAlpha = a;
            ctx.fillStyle = s.color;
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fill();
          }

          // Constellation lines
          ctx.lineWidth = 0.5;
          for (let i = 0; i < stars.length; i++) {
            for (let j = i + 1; j < stars.length; j++) {
              const dx = stars[i].x - stars[j].x;
              const dy = stars[i].y - stars[j].y;
              const d2 = dx * dx + dy * dy;
              if (d2 < CONN_DIST * CONN_DIST) {
                ctx.globalAlpha = (1 - Math.sqrt(d2) / CONN_DIST) * 0.13;
                ctx.strokeStyle = '#93c5fd';
                ctx.beginPath();
                ctx.moveTo(stars[i].x, stars[i].y);
                ctx.lineTo(stars[j].x, stars[j].y);
                ctx.stroke();
              }
            }
          }

          // Meteors
          if (Math.random() < 0.004) spawnMeteor();
          for (let i = meteors.length - 1; i >= 0; i--) {
            const m = meteors[i];
            m.x += m.vx; m.y += m.vy; m.life -= m.decay;
            if (m.life <= 0 || m.y > H + 20 || m.x < -20) { meteors.splice(i, 1); continue; }

            const spd = Math.hypot(m.vx, m.vy);
            const tx = m.x - m.vx * (m.len / spd);
            const ty = m.y - m.vy * (m.len / spd);
            const grad = ctx.createLinearGradient(m.x, m.y, tx, ty);
            const rgb = m.blue ? '147,197,253' : '226,232,240';
            grad.addColorStop(0, `rgba(255,255,255,${m.life.toFixed(2)})`);
            grad.addColorStop(0.3, `rgba(${rgb},${(m.life * 0.55).toFixed(2)})`);
            grad.addColorStop(1, 'rgba(0,0,0,0)');

            ctx.globalAlpha = 1;
            ctx.strokeStyle = grad;
            ctx.lineWidth = 1.5 * m.life;
            ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(m.x, m.y);
            ctx.lineTo(tx, ty);
            ctx.stroke();

            ctx.globalAlpha = m.life * 0.9;
            ctx.fillStyle = '#ffffff';
            ctx.beginPath();
            ctx.arc(m.x, m.y, 1.5 * m.life, 0, Math.PI * 2);
            ctx.fill();
          }

          ctx.globalAlpha = 1;
          requestAnimationFrame(draw);
        }

        window.addEventListener('resize', () => { resize(); initStars(); });
        resize();
        initStars();
        setTimeout(spawnMeteor, 800);
        setTimeout(spawnMeteor, 3000);
        draw();
      })();
    </script>
  </body>
</html>
