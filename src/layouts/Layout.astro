---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Duong Ngoc Vu — AI Researcher',
  description = 'Undergraduate Researcher at Business AI Lab, NEU. Research on AI for Healthcare and Fraud Detection.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔬</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
    <style>
      body { background: #dbeafe; }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: radial-gradient(circle, #93c5fd 1px, transparent 1px);
        background-size: 32px 32px;
        opacity: 0.25;
        pointer-events: none;
        z-index: 0;
      }
    </style>
  </head>
  <body class="bg-blue-100 text-slate-900 font-sans antialiased overflow-x-hidden">
    <!-- Floating gradient orbs -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index:0;">
      <div class="absolute top-0 right-1/4 w-[600px] h-[600px] rounded-full bg-blue-400/15 blur-[140px]"></div>
      <div class="absolute bottom-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-indigo-400/10 blur-[100px]"></div>
      <div class="absolute top-1/2 right-0 w-72 h-72 rounded-full bg-sky-300/15 blur-[80px]"></div>
    </div>

    <!-- Canvas for meteors only (no constellation - better performance) -->
    <canvas id="starfield-global" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index:0;"></canvas>

    <!-- Content -->
    <div class="relative" style="z-index:1;">
      <slot />
    </div>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" is:inline></script>
    <script is:inline>
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) window.location.reload();
      });

      AOS.init({ duration: 650, easing: 'ease-out-cubic', once: true, offset: 60 });

      // Light-mode meteor shower (no heavy starfield/constellation)
      (function () {
        const canvas = document.getElementById('starfield-global');
        const ctx = canvas.getContext('2d');
        let W, H, meteors = [];

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }

        function spawnMeteor() {
          const fromTop = Math.random() > 0.3;
          meteors.push({
            x: fromTop ? Math.random() * W * 0.8 : W + 10,
            y: fromTop ? -10 : Math.random() * H * 0.3,
            vx: -(4 + Math.random() * 6),
            vy:   3 + Math.random() * 5,
            len: 60 + Math.random() * 100,
            life: 1,
            decay: 0.014 + Math.random() * 0.018,
            blue: Math.random() > 0.4,
          });
        }

        function draw() {
          ctx.clearRect(0, 0, W, H);

          if (Math.random() < 0.018) spawnMeteor();

          for (let i = meteors.length - 1; i >= 0; i--) {
            const m = meteors[i];
            m.x += m.vx; m.y += m.vy; m.life -= m.decay;
            if (m.life <= 0 || m.y > H + 20 || m.x < -20) { meteors.splice(i, 1); continue; }

            const spd = Math.hypot(m.vx, m.vy);
            const tx = m.x - m.vx * (m.len / spd);
            const ty = m.y - m.vy * (m.len / spd);
            const grad = ctx.createLinearGradient(m.x, m.y, tx, ty);
            const rgb = m.blue ? '59,130,246' : '99,102,241';
            grad.addColorStop(0, `rgba(${rgb},${(m.life * 0.7).toFixed(2)})`);
            grad.addColorStop(0.4, `rgba(${rgb},${(m.life * 0.3).toFixed(2)})`);
            grad.addColorStop(1, 'rgba(0,0,0,0)');

            ctx.globalAlpha = 1;
            ctx.strokeStyle = grad;
            ctx.lineWidth = 1.5 * m.life;
            ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(m.x, m.y);
            ctx.lineTo(tx, ty);
            ctx.stroke();

            ctx.globalAlpha = m.life * 0.6;
            ctx.fillStyle = m.blue ? '#3b82f6' : '#6366f1';
            ctx.beginPath();
            ctx.arc(m.x, m.y, 1.5 * m.life, 0, Math.PI * 2);
            ctx.fill();
          }

          ctx.globalAlpha = 1;
          requestAnimationFrame(draw);
        }

        window.addEventListener('resize', resize);
        resize();
        setTimeout(spawnMeteor, 600);
        setTimeout(spawnMeteor, 1800);
        setTimeout(spawnMeteor, 3200);
        draw();
      })();
    </script>
  </body>
</html>
