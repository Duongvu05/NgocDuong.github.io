---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = posts.filter(p => p.data.featured);
const rest = posts.filter(p => !p.data.featured);
---

<Layout title="Blog — Duong Ngoc Vu">
  <Navbar />
  <main class="pt-28 pb-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

      <div class="mb-14" data-aos="fade-up">
        <p class="text-blue-600 font-mono text-sm font-medium mb-2">// writing</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">Blog</h1>
        <p class="text-slate-500">Research notes, technical writing, and updates.</p>
      </div>

      {featured.length > 0 && (
        <div class="mb-12">
          <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">Featured</h2>
          <div class="grid sm:grid-cols-2 gap-5">
            {featured.map((post, i) => (
              <a
                href={`/NgocDuong.github.io/blog/${post.slug}`}
                class="group block p-6 rounded-2xl bg-white border border-blue-200 hover:border-blue-400 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-blue-200/50 shadow-sm"
                data-aos="fade-up"
                data-aos-delay={i * 80}
              >
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {post.data.tags.map(tag => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 border border-blue-200 text-blue-700">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="font-bold text-slate-900 leading-snug mb-2 group-hover:text-blue-700 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-slate-500 text-sm leading-relaxed mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <time class="text-xs text-slate-400 font-mono">
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <span class="text-blue-600 text-sm group-hover:translate-x-1 transition-transform inline-block font-medium">
                    Read &rarr;
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {rest.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">All Posts</h2>
          <div class="divide-y divide-slate-200">
            {rest.map((post, i) => (
              <a
                href={`/NgocDuong.github.io/blog/${post.slug}`}
                class="group flex items-start justify-between gap-4 py-5 hover:bg-blue-50/60 -mx-3 px-3 rounded-xl transition-colors"
                data-aos="fade-up"
                data-aos-delay={i * 60}
              >
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap gap-1.5 mb-1.5">
                    {post.data.tags.map(tag => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 border border-slate-200 text-slate-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="font-semibold text-slate-900 group-hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-slate-500 mt-1 line-clamp-1">{post.data.description}</p>
                </div>
                <time class="text-xs text-slate-400 font-mono flex-shrink-0 mt-1">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </time>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </main>
  <Footer />
</Layout>
