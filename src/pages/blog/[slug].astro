---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} — Duong Ngoc Vu`} description={post.data.description}>
  <Navbar />
  <main class="pt-28 pb-24 min-h-screen">
    <div class="max-w-2xl mx-auto px-6">

      <!-- Back -->
      <a
        href="/NgocDuong.github.io/blog"
        class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-blue-400 transition-colors mb-10 group"
      >
        <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        All posts
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-1.5 mb-4">
          {post.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold text-white leading-snug mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-slate-500">
          <span>Duong Ngoc Vu</span>
          <span class="text-slate-700">·</span>
          <time class="font-mono">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </header>

      <div class="h-px bg-gradient-to-r from-blue-500/30 via-blue-500/10 to-transparent mb-10"></div>

      <!-- Content -->
      <article class="prose-custom">
        <Content />
      </article>

    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose-custom {
    color: #94a3b8;
    line-height: 1.8;
  }
  .prose-custom h2 {
    color: #f1f5f9;
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1e293b;
  }
  .prose-custom h3 {
    color: #e2e8f0;
    font-size: 1.05rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-custom p { margin-bottom: 1.2rem; }
  .prose-custom a {
    color: #60a5fa;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-custom a:hover { color: #93c5fd; }
  .prose-custom strong { color: #e2e8f0; font-weight: 600; }
  .prose-custom ul, .prose-custom ol {
    margin: 0.75rem 0 1rem 1.25rem;
    space-y: 0.4rem;
  }
  .prose-custom li { margin-bottom: 0.35rem; }
  .prose-custom code {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    color: #60a5fa;
    font-family: 'JetBrains Mono', monospace;
  }
  .prose-custom pre {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }
  .prose-custom pre code {
    background: none;
    border: none;
    padding: 0;
    color: #94a3b8;
    font-size: 0.85rem;
  }
  .prose-custom blockquote {
    border-left: 3px solid #3b82f6;
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: #64748b;
    font-style: italic;
  }
</style>
