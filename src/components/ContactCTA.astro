---
const base = '/NgocDuong.github.io';
---

<section class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-blue-300/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="relative rounded-3xl border border-blue-200 bg-gradient-to-br from-blue-50 via-white to-indigo-50 overflow-hidden p-10 sm:p-14">

      <!-- Background glow -->
      <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-blue-300/20 blur-[80px]"></div>
      <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-indigo-300/15 blur-[60px]"></div>

      <div class="relative z-10 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-10">

        <!-- Left text -->
        <div data-aos="fade-right">
          <p class="text-blue-600 font-mono text-sm font-medium mb-3">// contact</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">Let's Connect</h2>
          <p class="text-slate-600 max-w-md leading-relaxed">
            Open to research collaborations, PhD discussions, and opportunities in machine learning or medical AI.
            Feel free to reach out anytime.
          </p>
        </div>

        <!-- Right: contact options -->
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3 flex-shrink-0 w-full sm:w-auto" data-aos="fade-left">
          <a href="mailto:duongvn.bai@st.neu.edu.vn"
            class="flex items-center gap-3 px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold text-sm transition-all duration-200 shadow-lg shadow-blue-400/30 hover:-translate-y-0.5 whitespace-nowrap">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Send Email
          </a>
          <a href="https://www.linkedin.com/in/ngoc-duong-47a058292/" target="_blank"
            class="flex items-center gap-3 px-5 py-3 border border-slate-300 hover:border-blue-400 text-slate-700 hover:text-blue-600 rounded-xl font-semibold text-sm transition-all duration-200 hover:bg-blue-50 hover:-translate-y-0.5 whitespace-nowrap">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a href={`${base}/contact`}
            class="flex items-center gap-3 px-5 py-3 border border-slate-200 hover:border-slate-300 text-slate-500 hover:text-slate-700 rounded-xl font-semibold text-sm transition-all duration-200 hover:bg-slate-50 hover:-translate-y-0.5 whitespace-nowrap">
            More options
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
