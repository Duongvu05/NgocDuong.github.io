---
const contacts = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    label: 'Email',
    value: 'duongvn.bai@st.neu.edu.vn',
    href: 'mailto:duongvn.bai@st.neu.edu.vn',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
    label: 'GitHub',
    value: 'Duongvu05',
    href: 'https://github.com/Duongvu05',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    label: 'LinkedIn',
    value: 'ngoc-duong-47a058292',
    href: 'https://www.linkedin.com/in/ngoc-duong-47a058292/',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.872-1.591 3.872-3.722 0-2.016-1.503-3.722-3.862-3.722h-2.307z"/></svg>`,
    label: 'ORCID',
    value: '0009-0003-5917-4881',
    href: 'https://orcid.org/0009-0003-5917-4881',
  },
];
---

<section id="contact" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-blue-300/40 to-transparent"></div>

  <!-- Blue glow background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-64 rounded-full bg-blue-600/8 blur-[80px]"></div>
  </div>

  <div class="max-w-2xl mx-auto px-6 text-center">

    <div data-aos="fade-up">
      <p class="text-blue-700 font-mono text-sm font-medium mb-2">// 06. contact</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Get In Touch</h2>
      <p class="text-slate-400 leading-relaxed mb-10">
        I'm always open to research collaborations, internship opportunities, or just a good conversation
        about AI. Feel free to reach out!
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-3 mb-10" data-aos="fade-up" data-aos-delay="100">
      {
        contacts.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener"
            class="group flex items-center gap-3 p-4 rounded-xl bg-white border border-slate-200 hover:border-blue-400 hover:bg-blue-50 transition-all duration-200 text-left"
          >
            <div class="w-10 h-10 rounded-lg bg-blue-600/10 border border-blue-500/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600/20 group-hover:border-blue-500/40 transition-all flex-shrink-0">
              <Fragment set:html={c.icon} />
            </div>
            <div class="min-w-0">
              <p class="text-xs text-slate-500 mb-0.5">{c.label}</p>
              <p class="text-sm text-slate-700 font-medium group-hover:text-blue-700 transition-colors truncate">{c.value}</p>
            </div>
            <svg class="w-4 h-4 text-slate-700 group-hover:text-blue-400 transition-colors ml-auto flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        ))
      }
    </div>

    <div data-aos="fade-up" data-aos-delay="200">
      <a
        href="mailto:duongvn.bai@st.neu.edu.vn"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg shadow-blue-600/30 hover:shadow-blue-500/50 hover:-translate-y-0.5"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Say Hello
      </a>
    </div>
  </div>
</section>
