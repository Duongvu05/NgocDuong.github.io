---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 py-8 bg-white/60">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <img src="/NgocDuong.github.io/avatar.jpg" alt="Duong Ngoc Vu"
        class="w-7 h-7 rounded-md object-cover object-top ring-1 ring-blue-300/50" />
      <span class="text-slate-500 text-sm">Duong Ngoc Vu</span>
    </div>
    <p class="text-slate-400 text-sm">
      &copy; {year} · Built with
      <span class="text-blue-500">Astro</span> &
      <span class="text-blue-500">Tailwind CSS</span>
    </p>
    <div class="flex items-center gap-4">
      <a href="https://github.com/Duongvu05" target="_blank" class="text-slate-400 hover:text-blue-600 transition-colors text-sm">GitHub</a>
      <a href="https://www.linkedin.com/in/ngoc-duong-47a058292/" target="_blank" class="text-slate-400 hover:text-blue-600 transition-colors text-sm">LinkedIn</a>
      <a href="mailto:duongvn.bai@st.neu.edu.vn" class="text-slate-400 hover:text-blue-600 transition-colors text-sm">Email</a>
    </div>
  </div>
</footer>
