---
const radarAxes = [
  { label: 'Python',        value: 92 },
  { label: 'Deep Learning', value: 87 },
  { label: 'Transformers',  value: 82 },
  { label: 'MLOps',         value: 79 },
  { label: 'DevOps',        value: 76 },
  { label: 'Systems (C++)', value: 70 },
  { label: 'Data Eng.',     value: 74 },
  { label: 'Research',      value: 88 },
];

const skillGroups = [
  {
    group: 'Languages & Frameworks',
    color: '#3b82f6',
    items: [
      { name: 'Python',                  level: 92 },
      { name: 'PyTorch',                 level: 87 },
      { name: 'Transformers / HuggingFace', level: 82 },
      { name: 'TensorFlow',              level: 75 },
      { name: 'C++',                     level: 70 },
    ],
  },
  {
    group: 'MLOps & Tooling',
    color: '#8b5cf6',
    items: [
      { name: 'MLflow',           level: 78 },
      { name: 'Docker',           level: 76 },
      { name: 'Weights & Biases', level: 80 },
      { name: 'Git / DVC',        level: 85 },
      { name: 'Linux / Bash',     level: 80 },
    ],
  },
];
---

<section id="skills" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-blue-300/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-12" data-aos="fade-up">
      <p class="text-blue-600 font-mono text-sm font-medium mb-2">// skills</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Technical Skills</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">

      <!-- Left: D3 Radar Chart -->
      <div data-aos="fade-up">
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">Skill Radar</p>
        <div id="skill-radar" class="w-full" style="height:340px;"></div>
      </div>

      <!-- Right: Skill bars + languages -->
      <div data-aos="fade-up" data-aos-delay="100" class="space-y-8">
        {skillGroups.map((group, gi) => (
          <div>
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">{group.group}</h3>
            <div class="space-y-3">
              {group.items.map((s) => (
                <div class="flex items-center gap-3">
                  <span class="text-sm text-slate-700 w-44 flex-shrink-0">{s.name}</span>
                  <div class="flex-1 h-1.5 bg-slate-200 rounded-full overflow-hidden">
                    <div
                      class="skill-bar h-full rounded-full"
                      data-level={s.level}
                      style={`width:0%;background:${group.color};transition:width 1s cubic-bezier(0.4,0,0.2,1);`}
                    ></div>
                  </div>
                  <span class="text-xs font-mono text-slate-500 w-8 text-right">{s.level}</span>
                </div>
              ))}
            </div>
          </div>
        ))}

        <div class="pt-4 border-t border-slate-200">
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Languages</h3>
          <div class="flex gap-3">
            <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white text-sm border border-slate-200 shadow-sm">
              <span class="text-xs font-bold text-slate-500">VI</span>
              <span class="text-slate-700">Vietnamese</span>
              <span class="text-slate-400 text-xs">Native</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white text-sm border border-slate-200 shadow-sm">
              <span class="text-xs font-bold text-slate-500">EN</span>
              <span class="text-slate-700">English</span>
              <span class="text-slate-400 text-xs">Professional</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline define:vars={{ radarAxes }}>
(function () {
  // Skill bars
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll('.skill-bar').forEach((bar, i) => {
        setTimeout(() => { bar.style.width = bar.getAttribute('data-level') + '%'; }, i * 80);
      });
      barObserver.unobserve(entry.target);
    });
  }, { threshold: 0.2 });
  const skillSection = document.getElementById('skills');
  if (skillSection) barObserver.observe(skillSection);

  // Radar chart
  function drawRadar() {
    if (typeof d3 === 'undefined') return;
    const cont = document.getElementById('skill-radar');
    if (!cont) return;
    cont.innerHTML = '';

    const W = cont.clientWidth, H = cont.clientHeight || 340;
    const cx = W / 2, cy = H / 2;
    const R = Math.min(W, H) / 2 - 48;
    const N = radarAxes.length;
    const levels = 5;

    const svg = d3.select(cont).append('svg').attr('width', W).attr('height', H);
    const defs = svg.append('defs');

    // Glow filter
    const filt = defs.append('filter').attr('id', 'radar-glow');
    filt.append('feGaussianBlur').attr('stdDeviation', '3').attr('result', 'b');
    const fm = filt.append('feMerge');
    fm.append('feMergeNode').attr('in', 'b');
    fm.append('feMergeNode').attr('in', 'SourceGraphic');

    // Area fill gradient
    const grad = defs.append('radialGradient').attr('id', 'radar-fill');
    grad.append('stop').attr('offset', '0%').attr('stop-color', '#3b82f6').attr('stop-opacity', 0.35);
    grad.append('stop').attr('offset', '100%').attr('stop-color', '#6366f1').attr('stop-opacity', 0.08);

    const g = svg.append('g').attr('transform', `translate(${cx},${cy})`);

    function angleFor(i) { return (Math.PI * 2 * i / N) - Math.PI / 2; }
    function pt(i, val) {
      const a = angleFor(i);
      const r = (val / 100) * R;
      return [Math.cos(a) * r, Math.sin(a) * r];
    }

    // Grid rings
    for (let l = 1; l <= levels; l++) {
      const r = (l / levels) * R;
      const pts = Array.from({ length: N }, (_, i) => {
        const a = angleFor(i);
        return [Math.cos(a) * r, Math.sin(a) * r];
      });
      g.append('polygon')
        .attr('points', pts.map(p => p.join(',')).join(' '))
        .attr('fill', 'none')
        .attr('stroke', '#cbd5e1')
        .attr('stroke-width', l === levels ? 1 : 0.5);
    }

    // Axis spokes
    radarAxes.forEach((_, i) => {
      const [x, y] = pt(i, 100);
      g.append('line').attr('x1', 0).attr('y1', 0).attr('x2', x).attr('y2', y)
        .attr('stroke', '#cbd5e1').attr('stroke-width', 0.8);
    });

    // Data polygon (start at 0, animate to real values)
    const dataPoints = radarAxes.map((_, i) => pt(i, 0));
    const polyStr = (pts) => pts.map(p => p.join(',')).join(' ');

    const areaPoly = g.append('polygon')
      .attr('points', polyStr(dataPoints))
      .attr('fill', 'url(#radar-fill)')
      .attr('stroke', 'none');

    const linePoly = g.append('polygon')
      .attr('points', polyStr(dataPoints))
      .attr('fill', 'none')
      .attr('stroke', '#3b82f6')
      .attr('stroke-width', 2)
      .attr('filter', 'url(#radar-glow)');

    // Vertex dots
    const dots = g.selectAll('circle.rdot').data(radarAxes).join('circle')
      .attr('class', 'rdot')
      .attr('cx', 0).attr('cy', 0)
      .attr('r', 3.5)
      .attr('fill', '#3b82f6')
      .attr('stroke', '#93c5fd').attr('stroke-width', 1)
      .attr('filter', 'url(#radar-glow)');

    // Axis labels
    radarAxes.forEach((ax, i) => {
      const a = angleFor(i);
      const lx = Math.cos(a) * (R + 22);
      const ly = Math.sin(a) * (R + 22);
      const anchor = Math.abs(lx) < 5 ? 'middle' : lx > 0 ? 'start' : 'end';
      g.append('text')
        .attr('x', lx).attr('y', ly)
        .attr('text-anchor', anchor)
        .attr('dominant-baseline', 'central')
        .attr('font-size', '9px')
        .attr('font-family', 'Inter, sans-serif')
        .attr('fill', '#64748b')
        .text(ax.label);
    });

    // Animate in when visible
    const obs = new IntersectionObserver((entries) => {
      if (!entries[0].isIntersecting) return;
      obs.disconnect();
      const targetPts = radarAxes.map((_, i) => pt(i, radarAxes[i].value));
      const steps = 40;
      let step = 0;
      function tick() {
        step++;
        const t = d3.easeCubicOut(step / steps);
        const current = radarAxes.map((_, i) => {
          const [tx, ty] = targetPts[i];
          return [tx * t, ty * t];
        });
        areaPoly.attr('points', polyStr(current));
        linePoly.attr('points', polyStr(current));
        dots.attr('cx', (_, i) => current[i][0]).attr('cy', (_, i) => current[i][1]);
        if (step < steps) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }, { threshold: 0.3 });
    obs.observe(cont);
  }

  function load() {
    if (typeof d3 !== 'undefined') { drawRadar(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js';
    s.onload = drawRadar;
    document.head.appendChild(s);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', load);
  else load();
})();
</script>
