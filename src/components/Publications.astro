---
const papers = [
  {
    year: '2026',
    title: 'PhenSPINE: A Standardized Benchmark for Spine Pathology Diagnosis',
    authors: ['Duong Ngoc Vu', 'Hai Son Nguyen', 'Trong-Nghia Nguyen', 'Bien Tran Van', 'Trang Mai Xuan', 'Huan Vu', 'Thien Van Luong'],
    venue: 'CITA 2026',
    venueFull: '15th Conference on Information Technology and its Applications',
    tags: ['Medical Imaging', 'Benchmark', 'Spine', 'Healthcare'],
    featured: true,
    abstract: 'A standardized benchmark dataset and evaluation framework for spine pathology diagnosis, enabling fair comparison of deep learning methods on clinical MRI data.',
  },
  {
    year: '2026',
    title: 'CrossSpine: Multi-scale Cross-sequence Attention for Pfirrmann Grading',
    authors: ['Hai Son Nguyen', 'Duong Ngoc Vu', 'Trong-Nghia Nguyen', 'Bien Tran Van', 'Van-Dem Pham', 'Trang Mai Xuan', 'Huan Vu', 'Thien Van Luong'],
    venue: 'CITA 2026',
    venueFull: '15th Conference on Information Technology and its Applications',
    tags: ['Medical Imaging', 'Spine', 'Deep Learning'],
    featured: true,
    abstract: 'A multi-scale cross-sequence attention framework for automated Pfirrmann grading of spinal disc degeneration from MRI images.',
  },
];
---

<section id="publications" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-14" data-aos="fade-up">
      <p class="text-blue-400 font-mono text-sm font-medium mb-2">// 03. publications</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Publications</h2>
    </div>

    <div class="space-y-5">
      {
        papers.map((p, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={i * 100}
            class="group relative p-6 rounded-2xl bg-[#0f172a] border border-slate-800/60 hover:border-blue-500/30 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/5"
          >
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">

              <!-- Year badge -->
              <div class="flex-shrink-0">
                <span class="inline-block px-3 py-1 rounded-lg bg-blue-600/15 border border-blue-500/20 text-blue-400 text-sm font-mono font-medium">
                  {p.year}
                </span>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="font-bold text-white text-base sm:text-lg leading-snug group-hover:text-blue-100 transition-colors">
                    {p.title}
                  </h3>
                  {p.featured && (
                    <span class="flex-shrink-0 text-xs px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400">
                      Featured
                    </span>
                  )}
                </div>

                <!-- Authors -->
                <p class="text-sm text-slate-500 mb-2">
                  {p.authors.map((author, idx) => (
                    <span>
                      {author === 'Duong Ngoc Vu'
                        ? <strong class="text-slate-300 font-semibold">{author}</strong>
                        : <span>{author}</span>
                      }
                      {idx < p.authors.length - 1 ? ', ' : ''}
                    </span>
                  ))}
                </p>

                <!-- Venue -->
                <div class="flex items-center gap-2 mb-3">
                  <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                  <span class="text-sm text-blue-400 font-medium">{p.venue}</span>
                  <span class="text-slate-600 text-xs hidden sm:inline">· {p.venueFull}</span>
                </div>

                <!-- Abstract -->
                <p class="text-sm text-slate-500 leading-relaxed mb-3 hidden sm:block">{p.abstract}</p>

                <!-- Tags -->
                <div class="flex flex-wrap gap-1.5">
                  {p.tags.map(tag => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 border border-slate-700/50 text-slate-400">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Hover effect line -->
            <div class="absolute left-0 top-4 bottom-4 w-0.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        ))
      }
    </div>
  </div>
</section>
