---
const base = '/NgocDuong.github.io';
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/research`, label: 'Research' },
  { href: `${base}/experience`, label: 'Experience' },
  { href: `${base}/blog`, label: 'Blog' },
  { href: `${base}/contact`, label: 'Contact' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/NgocDuong.github.io/" class="flex items-center gap-3 group">
      <div
        class="w-9 h-9 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-blue-500/30 group-hover:shadow-blue-500/60 transition-shadow"
      >
        DV
      </div>
      <span class="font-semibold text-slate-200 hidden sm:block group-hover:text-white transition-colors">
        Duong Ngoc Vu
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="px-3 py-1.5 text-sm text-slate-400 hover:text-blue-400 hover:bg-blue-500/10 rounded-md transition-all duration-200 font-medium"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a
      href="/NgocDuong.github.io/cv.pdf"
      target="_blank"
      class="hidden md:flex items-center gap-2 px-4 py-2 border border-blue-500/50 text-blue-400 text-sm rounded-lg hover:bg-blue-500/10 hover:border-blue-400 transition-all duration-200 font-medium"
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
      </svg>
      CV
    </a>

    <button id="menu-btn" class="md:hidden p-2 text-slate-400 hover:text-white">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800/60 bg-[#020617]/95 backdrop-blur-xl px-6 py-4">
    {
      links.map((l) => (
        <a
          href={l.href}
          class="mobile-link block py-2.5 text-sm text-slate-400 hover:text-blue-400 transition-colors border-b border-slate-800/40 last:border-0"
        >
          {l.label}
        </a>
      ))
    }
  </div>
</header>

<script is:inline>
  const navbar = document.getElementById('navbar');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-[#020617]/90', 'backdrop-blur-xl', 'border-b', 'border-slate-800/60', 'shadow-xl', 'shadow-black/20');
    } else {
      navbar.classList.remove('bg-[#020617]/90', 'backdrop-blur-xl', 'border-b', 'border-slate-800/60', 'shadow-xl', 'shadow-black/20');
    }
  });

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
  });
</script>
