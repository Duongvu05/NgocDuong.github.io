---
const items = [
  {
    title: 'Outstanding Student Award — Faculty of Mathematical Economics, NEU 2025-2026',
    org: 'National Economics University',
    date: 'May 2026',
    sortDate: '2026-05',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Reviewer — CITA 2026',
    org: 'Conference on Information Technology and Its Applications',
    date: 'Feb 2026',
    sortDate: '2026-02',
    badge: 'Reviewer',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'First Prize — Faculty-level Scientific Research Competition',
    org: 'Faculty of Data Science and AI, NEU',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Reviewer — FJCAI 2026',
    org: 'National Conference on Artificial Intelligence',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Reviewer',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'Teaching Assistant — Machine Learning, NEU',
    org: 'National Economics University',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Teaching',
    dotColor: '#8b5cf6',
    badgeColor: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
    borderColor: 'border-violet-500/20',
  },
  {
    title: 'Outstanding Member of Business AI Lab 2025',
    org: 'Business AI Lab, NEU',
    date: 'Dec 2025',
    sortDate: '2025-12',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Consolation Prize — Vietnam Student AI Olympics 2025 (Northern Region)',
    org: 'Vietnam Student AI Olympics',
    date: 'Dec 2025',
    sortDate: '2025-12',
    badge: 'Competition',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'First Prize — Biztech Hackathon 2025 (A.ignite)',
    org: 'Biztech Hackathon',
    date: 'Mar 2025',
    sortDate: '2025-03',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Mentor — Fulbright STEM Mentorship Program',
    org: 'U.S. Embassy Hanoi',
    date: 'Feb – May 2025',
    sortDate: '2025-02',
    badge: 'Mentorship',
    dotColor: '#0ea5e9',
    badgeColor: 'bg-sky-500/10 text-sky-400 border-sky-500/20',
    borderColor: 'border-sky-500/20',
  },
].sort((a, b) => b.sortDate.localeCompare(a.sortDate));

// Build flat render list with year dividers
const grouped: Record<string, typeof items> = {};
for (const item of items) {
  const year = item.sortDate.slice(0, 4);
  if (!grouped[year]) grouped[year] = [];
  grouped[year].push(item);
}
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

type RenderItem =
  | { type: 'year'; year: string }
  | { type: 'item'; item: typeof items[0]; idx: number };

const renderList: RenderItem[] = [];
for (const year of years) {
  renderList.push({ type: 'year', year });
  grouped[year].forEach((item, i) => renderList.push({ type: 'item', item, idx: i }));
}
---

<section id="awards" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-12" data-aos="fade-up">
      <p class="text-blue-400 font-mono text-sm font-medium mb-2">// 05. activities</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Awards & Activities</h2>
      <p class="text-slate-500 text-sm mt-2 font-mono">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
    </div>

    <!-- Horizontal timeline -->
    <div class="overflow-x-auto -mx-6 px-6 pb-6" data-aos="fade-up" data-aos-delay="100">
      <div class="relative inline-flex items-stretch" style="min-width: max-content; height: 440px;">

        <!-- Horizontal center line -->
        <div class="absolute left-0 right-0 h-px" style="top:50%; background: linear-gradient(to right, transparent, #3b82f640 5%, #3b82f640 95%, transparent);"></div>

        {renderList.map((entry, ri) => {
          if (entry.type === 'year') {
            return (
              <div class="relative flex-shrink-0 flex flex-col items-center justify-center" style="width:64px;">
                <div class="absolute z-10 px-2 py-1 rounded-full border border-blue-500/30 bg-[#020617]"
                  style="top:50%; transform:translateY(-50%);">
                  <span class="text-xs font-bold font-mono text-blue-400">{entry.year}</span>
                </div>
              </div>
            );
          }

          const { item, idx } = entry;
          const above = idx % 2 === 0;

          return (
            <div class="relative flex-shrink-0" style="width:220px; padding: 0 8px;">

              {/* Card above line */}
              {above && (
                <div class={`absolute left-2 right-2 p-3 rounded-xl bg-[#0f172a] border ${item.borderColor} hover:border-opacity-70 transition-all duration-200 group hover:-translate-y-0.5`}
                  style="bottom: calc(50% + 24px);">
                  <div class="flex items-start justify-between gap-2 mb-1.5">
                    <h4 class="text-xs font-semibold text-white leading-snug group-hover:text-blue-100 transition-colors line-clamp-3">
                      {item.title}
                    </h4>
                    <span class={`flex-shrink-0 text-[10px] px-1.5 py-0.5 rounded-full border font-medium ${item.badgeColor}`}>
                      {item.badge}
                    </span>
                  </div>
                  <p class="text-[10px] text-slate-500 leading-snug">{item.org}</p>
                </div>
              )}

              {/* Date label above dot */}
              <div class={`absolute left-1/2 -translate-x-1/2 text-[10px] font-mono whitespace-nowrap`}
                style={`color:#475569; ${above ? 'top: calc(50% + 14px)' : 'bottom: calc(50% + 14px)'};`}>
                {item.date.replace(/\s*\d{4}/, '').trim() || item.date}
              </div>

              {/* Dot on line */}
              <div class="absolute left-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rounded-full z-10"
                style={`top:50%; border: 2px solid ${item.dotColor}; background:#020617; box-shadow: 0 0 8px ${item.dotColor}80;`}>
              </div>

              {/* Card below line */}
              {!above && (
                <div class={`absolute left-2 right-2 p-3 rounded-xl bg-[#0f172a] border ${item.borderColor} hover:border-opacity-70 transition-all duration-200 group hover:translate-y-0.5`}
                  style="top: calc(50% + 24px);">
                  <div class="flex items-start justify-between gap-2 mb-1.5">
                    <h4 class="text-xs font-semibold text-white leading-snug group-hover:text-blue-100 transition-colors line-clamp-3">
                      {item.title}
                    </h4>
                    <span class={`flex-shrink-0 text-[10px] px-1.5 py-0.5 rounded-full border font-medium ${item.badgeColor}`}>
                      {item.badge}
                    </span>
                  </div>
                  <p class="text-[10px] text-slate-500 leading-snug">{item.org}</p>
                </div>
              )}

            </div>
          );
        })}

      </div>
    </div>

    <p class="text-xs text-slate-700 font-mono mt-2 text-center">scroll to see more →</p>

  </div>
</section>
