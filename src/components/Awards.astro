---
const items = [
  {
    title: 'SCIC Scholarship — "SCIC - Nâng bước tài năng trẻ" 2026',
    org: 'State Capital Investment Corporation (SCIC)',
    date: '2026',
    sortDate: '2026-06',
    badge: 'Scholarship',
    dotColor: '#dc2626',
    badgeColor: 'bg-red-500/10 text-red-500 border-red-500/20',
    borderColor: 'border-red-500/20',
  },
  {
    title: 'Outstanding Student Award — Faculty of Mathematical Economics, NEU 2025-2026',
    org: 'National Economics University',
    date: 'May 2026',
    sortDate: '2026-05',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Reviewer — CITA 2026',
    org: 'Conference on Information Technology and Its Applications',
    date: 'Feb 2026',
    sortDate: '2026-02',
    badge: 'Reviewer',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'First Prize — Faculty-level Scientific Research Competition',
    org: 'Faculty of Data Science and AI, NEU',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Reviewer — FJCAI 2026',
    org: 'National Conference on Artificial Intelligence',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Reviewer',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'Teaching Assistant — Machine Learning, NEU',
    org: 'National Economics University',
    date: 'Jan 2026',
    sortDate: '2026-01',
    badge: 'Teaching',
    dotColor: '#8b5cf6',
    badgeColor: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
    borderColor: 'border-violet-500/20',
  },
  {
    title: 'Outstanding Member of Business AI Lab 2025',
    org: 'Business AI Lab, NEU',
    date: 'Dec 2025',
    sortDate: '2025-12',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Consolation Prize — Vietnam Student AI Olympics 2025 (Northern Region)',
    org: 'Vietnam Student AI Olympics',
    date: 'Dec 2025',
    sortDate: '2025-12',
    badge: 'Competition',
    dotColor: '#3b82f6',
    badgeColor: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    borderColor: 'border-blue-500/20',
  },
  {
    title: 'First Prize — Biztech Hackathon 2025 (A.ignite)',
    org: 'Biztech Hackathon',
    date: 'Mar 2025',
    sortDate: '2025-03',
    badge: 'Award',
    dotColor: '#f59e0b',
    badgeColor: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
    borderColor: 'border-amber-500/20',
  },
  {
    title: 'Mentor — Fulbright STEM Mentorship Program',
    org: 'U.S. Embassy Hanoi',
    date: 'Feb – May 2025',
    sortDate: '2025-02',
    badge: 'Mentorship',
    dotColor: '#0ea5e9',
    badgeColor: 'bg-sky-500/10 text-sky-400 border-sky-500/20',
    borderColor: 'border-sky-500/20',
  },
].sort((a, b) => b.sortDate.localeCompare(a.sortDate));

// Build flat render list with year dividers
const grouped: Record<string, typeof items> = {};
for (const item of items) {
  const year = item.sortDate.slice(0, 4);
  if (!grouped[year]) grouped[year] = [];
  grouped[year].push(item);
}
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

type RenderItem =
  | { type: 'year'; year: string }
  | { type: 'item'; item: typeof items[0]; idx: number };

const renderList: RenderItem[] = [];
for (const year of years) {
  renderList.push({ type: 'year', year });
  grouped[year].forEach((item, i) => renderList.push({ type: 'item', item, idx: i }));
}
---

<section id="awards" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-300/60 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-12" data-aos="fade-up">
      <p class="text-blue-600 font-mono text-sm font-medium mb-2">// 05. activities</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Awards & Activities</h2>
      <p class="text-slate-500 text-sm mt-2 font-mono">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
    </div>

    <!-- Vertical timeline -->
    <div class="relative max-w-3xl" data-aos="fade-up" data-aos-delay="100">
      <div class="absolute left-[5.5rem] top-0 bottom-0 w-px bg-gradient-to-b from-blue-500/40 via-slate-700/40 to-transparent hidden sm:block"></div>

      <div class="space-y-10">
        {years.map((year) => (
          <div>
            <div class="flex items-center gap-4 mb-6">
              <div class="hidden sm:flex w-[5.5rem] justify-end pr-4">
                <span class="text-xs font-bold font-mono text-blue-400 bg-blue-500/10 border border-blue-500/20 px-2 py-0.5 rounded-full">
                  {year}
                </span>
              </div>
              <div class="sm:hidden text-xs font-bold font-mono text-blue-400 bg-blue-500/10 border border-blue-500/20 px-2 py-0.5 rounded-full">
                {year}
              </div>
            </div>

            <div class="space-y-4">
              {grouped[year].map((item, i) => (
                <div class="flex items-start gap-4 sm:gap-0" data-aos="fade-up" data-aos-delay={i * 70}>
                  <div class="hidden sm:flex w-[5.5rem] flex-shrink-0 justify-end pr-6 pt-3">
                    <span class="text-xs text-slate-600 font-mono text-right leading-tight">
                      {item.date.replace(/\s*\d{4}/, '').trim() || item.date}
                    </span>
                  </div>
                  <div class="hidden sm:flex flex-shrink-0 w-3 h-3 rounded-full border-2 mt-3.5 -ml-1.5 z-10"
                    style={`border-color: ${item.dotColor}; background: #020617; box-shadow: 0 0 8px ${item.dotColor}60;`}>
                  </div>
                  <div class={`flex-1 sm:ml-5 p-4 rounded-xl bg-white border ${item.borderColor} hover:border-opacity-70 transition-all duration-300 group hover:shadow-md hover:-translate-y-0.5`}>
                    <div class="flex items-start justify-between gap-3">
                      <h4 class="font-semibold text-slate-900 text-sm leading-snug group-hover:text-blue-700 transition-colors">
                        {item.title}
                      </h4>
                      <span class={`flex-shrink-0 text-xs px-2 py-0.5 rounded-full border font-medium ${item.badgeColor}`}>
                        {item.badge}
                      </span>
                    </div>
                    <div class="flex items-center justify-between mt-2">
                      <p class="text-xs text-slate-500">{item.org}</p>
                      <p class="text-xs text-slate-600 font-mono sm:hidden">{item.date}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
