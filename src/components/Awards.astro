<section id="awards" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-14" data-aos="fade-up">
      <p class="text-blue-400 font-mono text-sm font-medium mb-2">// 05. activities</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Awards & Activities</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        items.map((item, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={Math.min(i * 60, 300)}
            class={`relative p-5 rounded-xl bg-gradient-to-br ${item.color} border transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg group`}
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <div class="w-8 h-8 rounded-md bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0">
                <span class="text-xs font-bold font-mono text-slate-300">{item.label}</span>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded-full border font-medium ${item.badgeColor}`}>
                {item.badge}
              </span>
            </div>
            <h4 class="font-semibold text-white text-sm leading-snug mb-1.5 group-hover:text-blue-100 transition-colors">
              {item.title}
            </h4>
            <p class="text-xs text-slate-500 mb-1">{item.org}</p>
            <p class="text-xs text-slate-600 font-mono">{item.date}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
