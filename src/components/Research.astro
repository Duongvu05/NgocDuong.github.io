---
const areas = [
  {
    icon: '🏥',
    title: 'AI for Healthcare',
    color: 'from-blue-600/20 to-cyan-600/10',
    border: 'border-blue-500/20 hover:border-blue-500/50',
    glow: 'group-hover:shadow-blue-500/10',
    tags: ['Medical Imaging', 'MRI Analysis', 'Clinical AI'],
    description:
      'Multimodal deep learning frameworks for spine pathology diagnosis (Pfirrmann grading) on MRI sequences. Building benchmark datasets for standardized evaluation of clinical AI systems.',
  },
  {
    icon: '🔗',
    title: 'Fraud Detection',
    color: 'from-indigo-600/20 to-blue-600/10',
    border: 'border-indigo-500/20 hover:border-indigo-500/50',
    glow: 'group-hover:shadow-indigo-500/10',
    tags: ['Blockchain', 'Graph Neural Networks', 'Ethereum'],
    description:
      'Structural temporal graph networks for detecting fraudulent transactions on Ethereum. Feature selection techniques and dynamic graph representation for financial security.',
  },
  {
    icon: '🧠',
    title: 'Attention Mechanisms',
    color: 'from-sky-600/20 to-blue-600/10',
    border: 'border-sky-500/20 hover:border-sky-500/50',
    glow: 'group-hover:shadow-sky-500/10',
    tags: ['Transformers', 'Cross-Attention', 'Multi-scale'],
    description:
      'Designing cross-sequence attention architectures that fuse multi-scale visual features across different MRI modalities for robust pathology localization and grading.',
  },
  {
    icon: '📊',
    title: 'Benchmark Datasets',
    color: 'from-blue-600/20 to-violet-600/10',
    border: 'border-blue-500/20 hover:border-violet-500/50',
    glow: 'group-hover:shadow-violet-500/10',
    tags: ['Dataset Curation', 'Annotation', 'Evaluation'],
    description:
      'Creating standardized, well-annotated datasets (PhenSPINE) to enable fair and reproducible comparison of deep learning methods on spine MRI clinical data.',
  },
];
---

<section id="research" class="py-24 relative">
  <!-- Section divider -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-14" data-aos="fade-up">
      <p class="text-blue-400 font-mono text-sm font-medium mb-2">// 02. research</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Research Focus</h2>
      <p class="text-slate-400 mt-3 max-w-xl">
        Building AI systems that solve real-world problems in healthcare and financial security.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {
        areas.map((area, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={i * 80}
            class={`group relative p-6 rounded-2xl bg-gradient-to-br ${area.color} border ${area.border} transition-all duration-300 hover:shadow-xl ${area.glow} cursor-default`}
          >
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl flex-shrink-0">{area.icon}</div>
              <div>
                <h3 class="font-bold text-white text-lg leading-tight">{area.title}</h3>
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {area.tags.map(tag => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-slate-400">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed">{area.description}</p>
            <!-- Hover glow corner -->
            <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-blue-400/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        ))
      }
    </div>
  </div>
</section>
