---
---

<section id="research" class="py-24 relative">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-10" data-aos="fade-up">
      <p class="text-blue-400 font-mono text-sm font-medium mb-2">// 02. research</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Research Focus</h2>
      <p class="text-slate-400 mt-3 max-w-xl">Building AI systems that solve real-world problems in healthcare and financial security.</p>
    </div>

    <!-- Graph + Info panel -->
    <div class="flex flex-col lg:flex-row gap-6 items-start" data-aos="fade-up" data-aos-delay="100">

      <!-- D3 Graph -->
      <div class="w-full lg:w-3/5 xl:w-2/3">
        <div id="research-focus-graph" class="w-full rounded-2xl border border-slate-800/60 bg-[#060f1e]/80" style="height:420px;"></div>
        <p class="text-center text-xs text-slate-600 mt-2 font-mono">click a node to explore · drag to rearrange</p>
      </div>

      <!-- Info panel -->
      <div class="w-full lg:w-2/5 xl:w-1/3">
        <div id="research-info-panel" class="rounded-2xl border border-slate-800/60 bg-[#0a1628] p-6 min-h-[180px] transition-all duration-300">
          <p class="text-slate-600 text-sm text-center mt-8 font-mono">← click a research area</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function() {
  const graphData = {
    nodes: [
      { id: 'root',  label: 'Research',             abbr: 'R',   r: 32, type: 'root' },
      { id: 'hc',   label: 'AI for Healthcare',     abbr: 'HC',  r: 26, type: 'area', color: '#3b82f6',
        desc: 'Multimodal deep learning frameworks for spine pathology diagnosis (Pfirrmann grading) on MRI sequences. Building benchmark datasets for standardized evaluation of clinical AI systems.',
        tags: ['Medical Imaging', 'MRI Analysis', 'Clinical AI'] },
      { id: 'fd',   label: 'Fraud Detection',       abbr: 'FD',  r: 26, type: 'area', color: '#6366f1',
        desc: 'Structural temporal graph networks for detecting fraudulent transactions on Ethereum. Feature selection and dynamic graph representation for financial security.',
        tags: ['Blockchain', 'Graph Neural Networks', 'Ethereum'] },
      { id: 'at',   label: 'Attention Mechanisms',  abbr: 'AT',  r: 26, type: 'area', color: '#0ea5e9',
        desc: 'Designing cross-sequence attention architectures that fuse multi-scale visual features across different MRI modalities for robust pathology localization and grading.',
        tags: ['Transformers', 'Cross-Attention', 'Multi-scale'] },
      { id: 'bd',   label: 'Benchmark Datasets',    abbr: 'BD',  r: 26, type: 'area', color: '#8b5cf6',
        desc: 'Creating standardized, well-annotated datasets (PhenSPINE) to enable fair and reproducible comparison of deep learning methods on spine MRI clinical data.',
        tags: ['Dataset Curation', 'Annotation', 'Evaluation'] },
      // sub-nodes
      { id: 'mi',   label: 'Medical\nImaging',      abbr: 'MI',  r: 15, type: 'tag', parent: 'hc', color: '#3b82f6' },
      { id: 'mri',  label: 'MRI\nAnalysis',         abbr: 'MRI', r: 15, type: 'tag', parent: 'hc', color: '#3b82f6' },
      { id: 'ca',   label: 'Clinical\nAI',          abbr: 'CAI', r: 15, type: 'tag', parent: 'hc', color: '#3b82f6' },
      { id: 'bc',   label: 'Blockchain',            abbr: 'BC',  r: 15, type: 'tag', parent: 'fd', color: '#6366f1' },
      { id: 'gnn',  label: 'Graph\nNeural Nets',    abbr: 'GNN', r: 15, type: 'tag', parent: 'fd', color: '#6366f1' },
      { id: 'eth',  label: 'Ethereum',              abbr: 'ETH', r: 15, type: 'tag', parent: 'fd', color: '#6366f1' },
      { id: 'tr',   label: 'Transformers',          abbr: 'TR',  r: 15, type: 'tag', parent: 'at', color: '#0ea5e9' },
      { id: 'cx',   label: 'Cross\nAttention',      abbr: 'CA',  r: 15, type: 'tag', parent: 'at', color: '#0ea5e9' },
      { id: 'ms',   label: 'Multi-\nscale',         abbr: 'MS',  r: 15, type: 'tag', parent: 'at', color: '#0ea5e9' },
      { id: 'dc',   label: 'Dataset\nCuration',     abbr: 'DC',  r: 15, type: 'tag', parent: 'bd', color: '#8b5cf6' },
      { id: 'an',   label: 'Annotation',            abbr: 'AN',  r: 15, type: 'tag', parent: 'bd', color: '#8b5cf6' },
      { id: 'ev',   label: 'Evaluation',            abbr: 'EV',  r: 15, type: 'tag', parent: 'bd', color: '#8b5cf6' },
    ],
    links: [
      { source: 'root', target: 'hc' },
      { source: 'root', target: 'fd' },
      { source: 'root', target: 'at' },
      { source: 'root', target: 'bd' },
      { source: 'hc', target: 'mi' },
      { source: 'hc', target: 'mri' },
      { source: 'hc', target: 'ca' },
      { source: 'fd', target: 'bc' },
      { source: 'fd', target: 'gnn' },
      { source: 'fd', target: 'eth' },
      { source: 'at', target: 'tr' },
      { source: 'at', target: 'cx' },
      { source: 'at', target: 'ms' },
      { source: 'bd', target: 'dc' },
      { source: 'bd', target: 'an' },
      { source: 'bd', target: 'ev' },
      // Cross-links
      { source: 'hc', target: 'at', dashed: true },
      { source: 'hc', target: 'bd', dashed: true },
      { source: 'fd', target: 'gnn', dashed: false },
    ],
  };

  function initResearchGraph() {
    if (typeof d3 === 'undefined') return;
    const container = document.getElementById('research-focus-graph');
    const panel = document.getElementById('research-info-panel');
    if (!container || !panel) return;

    const W = container.clientWidth;
    const H = container.clientHeight || 420;
    container.innerHTML = '';

    const svg = d3.select(container).append('svg').attr('width', W).attr('height', H);
    const defs = svg.append('defs');

    // Glow filter
    const glow = defs.append('filter').attr('id', 'rfglow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    glow.append('feGaussianBlur').attr('stdDeviation', '4').attr('result', 'coloredBlur');
    const feMerge = glow.append('feMerge');
    feMerge.append('feMergeNode').attr('in', 'coloredBlur');
    feMerge.append('feMergeNode').attr('in', 'SourceGraphic');

    const nodes = graphData.nodes.map(d => ({ ...d }));
    const links = graphData.links.map(d => ({ ...d }));

    const sim = d3.forceSimulation(nodes)
      .force('link', d3.forceLink(links).id(d => d.id).distance(d => {
        const s = nodes.find(n => n.id === (d.source.id || d.source));
        const t = nodes.find(n => n.id === (d.target.id || d.target));
        if (s && t && s.type === 'area' && t.type === 'area') return 160;
        if (s && s.type === 'root') return 130;
        return 75;
      }).strength(0.6))
      .force('charge', d3.forceManyBody().strength(d => d.type === 'root' ? -600 : d.type === 'area' ? -350 : -120))
      .force('center', d3.forceCenter(W / 2, H / 2))
      .force('collision', d3.forceCollide().radius(d => d.r + 14));

    // Links
    const linkEls = svg.append('g').selectAll('line').data(links).join('line')
      .attr('stroke', d => {
        if (d.dashed) return '#334155';
        const src = nodes.find(n => n.id === (d.source.id || d.source));
        return src && src.color ? src.color + '60' : '#3b82f660';
      })
      .attr('stroke-width', d => d.dashed ? 1 : 1.5)
      .attr('stroke-dasharray', d => d.dashed ? '4 3' : null)
      .attr('opacity', 0.7);

    // Animate dashes on primary links
    function animateDashes() {
      linkEls.filter(d => !d.dashed).transition().duration(2200).ease(d3.easeLinear)
        .attr('stroke-dashoffset', -18)
        .on('end', animateDashes);
    }
    linkEls.filter(d => !d.dashed).attr('stroke-dasharray', '5 4').attr('stroke-dashoffset', 0);
    animateDashes();

    // Node groups
    let selected = null;
    const nodeG = svg.append('g').selectAll('g').data(nodes).join('g')
      .style('cursor', d => d.type !== 'tag' ? 'pointer' : 'default')
      .call(d3.drag()
        .on('start', (e, d) => { if (!e.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', (e, d) => { d.fx = e.x; d.fy = e.y; })
        .on('end', (e, d) => { if (!e.active) sim.alphaTarget(0); d.fx = null; d.fy = null; }));

    // Outer glow ring
    nodeG.append('circle')
      .attr('r', d => d.r + 7)
      .attr('fill', 'none')
      .attr('stroke', d => d.type === 'root' ? 'rgba(147,197,253,0.25)' : d.color ? d.color + '25' : '#3b82f625')
      .attr('stroke-width', 2)
      .attr('filter', 'url(#rfglow)');

    // Main circle
    nodeG.append('circle')
      .attr('r', d => d.r)
      .attr('fill', d => d.type === 'root' ? '#1e3a5f' : '#0a1628')
      .attr('stroke', d => d.type === 'root' ? '#93c5fd' : d.color || '#3b82f6')
      .attr('stroke-width', d => d.type === 'root' ? 2.5 : 1.5)
      .attr('filter', 'url(#rfglow)');

    // Abbr text
    nodeG.append('text')
      .attr('text-anchor', 'middle').attr('dominant-baseline', 'central')
      .attr('font-size', d => d.type === 'root' ? '10px' : d.type === 'area' ? '9px' : '6.5px')
      .attr('font-family', 'JetBrains Mono, monospace').attr('font-weight', '700')
      .attr('fill', d => d.type === 'root' ? '#bfdbfe' : d.color || '#93c5fd')
      .text(d => d.abbr);

    // Label below
    nodeG.each(function(d) {
      const el = d3.select(this);
      const lines = d.label.split('\n');
      const yOff = d.r + 9;
      const t = el.append('text')
        .attr('text-anchor', 'middle')
        .attr('font-size', d.type === 'tag' ? '5.5px' : '7px')
        .attr('font-family', 'Inter, sans-serif').attr('font-weight', '500')
        .attr('fill', d.type === 'root' ? '#94a3b8' : '#64748b');
      lines.forEach((line, i) => {
        t.append('tspan').attr('x', 0).attr('dy', i === 0 ? yOff : '1.2em').text(line);
      });
    });

    // Click handler
    nodeG.on('click', function(event, d) {
      if (d.type !== 'area') return;
      selected = d.id;
      // Highlight
      nodeG.select('circle:nth-of-type(2)')
        .attr('stroke-width', n => n.id === d.id ? 2.5 : n.type === 'root' ? 2.5 : 1.5)
        .attr('stroke', n => n.id === d.id ? (n.color || '#3b82f6') : n.type === 'root' ? '#93c5fd' : n.color || '#3b82f6');
      // Update panel
      const tagHtml = d.tags.map(tag =>
        `<span class="inline-block text-xs px-2 py-0.5 rounded-full border font-medium mr-1.5 mb-1.5" style="background:${d.color}18;color:${d.color};border-color:${d.color}40">${tag}</span>`
      ).join('');
      panel.innerHTML = `
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-bold font-mono flex-shrink-0" style="background:${d.color}20;color:${d.color};border:1px solid ${d.color}40">${d.abbr}</div>
          <h3 class="text-white font-bold text-base leading-tight">${d.label}</h3>
        </div>
        <div class="mb-3">${tagHtml}</div>
        <p class="text-slate-400 text-sm leading-relaxed">${d.desc}</p>
      `;
    });

    // Pulse on root
    function pulse() {
      nodeG.filter(d => d.type === 'root').select('circle:nth-of-type(1)')
        .transition().duration(1300).ease(d3.easeSinInOut)
        .attr('r', d => d.r + 13).attr('stroke-opacity', 0.08)
        .transition().duration(1300).ease(d3.easeSinInOut)
        .attr('r', d => d.r + 7).attr('stroke-opacity', 0.25)
        .on('end', pulse);
    }
    pulse();

    sim.on('tick', () => {
      linkEls
        .attr('x1', d => d.source.x).attr('y1', d => d.source.y)
        .attr('x2', d => d.target.x).attr('y2', d => d.target.y);
      nodeG.attr('transform', d => `translate(${
        Math.max(d.r + 8, Math.min(W - d.r - 8, d.x))},${
        Math.max(d.r + 8, Math.min(H - d.r - 8, d.y))})`);
    });

    setTimeout(() => sim.alphaDecay(0.02), 2500);
  }

  function tryInit() {
    if (typeof d3 !== 'undefined') { initResearchGraph(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js';
    s.onload = initResearchGraph;
    document.head.appendChild(s);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryInit);
  } else {
    tryInit();
  }
})();
</script>
