---
const base = '/NgocDuong.github.io';
const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/Duongvu05',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/ngoc-duong-47a058292/',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:duongvn.bai@st.neu.edu.vn',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: 'ORCID',
    href: 'https://orcid.org/0009-0003-5917-4881',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.872-1.591 3.872-3.722 0-2.016-1.503-3.722-3.862-3.722h-2.307z"/></svg>`,
  },
];

const stats = [
  { value: '2', label: 'Publications', color: 'blue' },
  { value: '3.7', label: 'GPA / 4.0', color: 'indigo' },
  { value: '5+', label: 'Awards', color: 'amber' },
];
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden pt-20">

  <!-- Hero glow orbs (starfield from Layout global) -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute top-1/4 left-1/3 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[160px]"></div>
    <div class="absolute bottom-1/4 right-1/3 w-80 h-80 rounded-full bg-indigo-600/8 blur-[120px]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 w-full py-16">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text -->
      <div class="order-2 lg:order-1 space-y-6">
        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-xs font-medium opacity-0 animate-fade-up" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
          Open to Research Collaboration
        </div>

        <!-- Name -->
        <div class="opacity-0 animate-fade-up" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
          <p class="text-slate-500 font-mono text-sm mb-1">Hi, I'm</p>
          <h1 class="text-5xl sm:text-6xl font-extrabold leading-none tracking-tight">
            <span class="bg-gradient-to-r from-white via-blue-100 to-blue-300 bg-clip-text text-transparent">Duong</span><br/>
            <span class="bg-gradient-to-r from-blue-400 via-blue-300 to-indigo-400 bg-clip-text text-transparent bg-300% animate-gradient-x">Ngoc Vu</span>
          </h1>
        </div>

        <!-- Role -->
        <div class="opacity-0 animate-fade-up" style="animation-delay: 0.3s; animation-fill-mode: forwards;">
          <p class="text-slate-400 text-base leading-relaxed">
            Undergraduate Researcher at
            <a href="https://bailab.vn/" target="_blank" class="text-blue-400 hover:text-blue-300 transition-colors font-medium">Business AI Lab, NEU</a>.
            Working on <span class="text-slate-200 font-medium">AI for Healthcare</span> and
            <span class="text-slate-200 font-medium">Graph-based Fraud Detection</span>
            under <a href="https://tvluong.wordpress.com/" target="_blank" class="text-blue-400 hover:text-blue-300 transition-colors">Dr. Thien Van Luong</a>.
          </p>
          <p class="text-slate-500 text-sm mt-2">
            Seeking <span class="text-slate-400">RA / PhD positions</span> in ML, medical AI, or computer vision — starting 2027.
          </p>
        </div>

        <!-- Stats row -->
        <div class="flex gap-6 opacity-0 animate-fade-up" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
          {stats.map(s => (
            <div class="text-center">
              <p class={`text-2xl font-extrabold font-mono ${s.color === 'amber' ? 'text-amber-400' : 'text-blue-400'}`}>{s.value}</p>
              <p class="text-xs text-slate-500 mt-0.5">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 opacity-0 animate-fade-up" style="animation-delay: 0.5s; animation-fill-mode: forwards;">
          <a href={`${base}/research`}
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-semibold text-sm transition-all duration-200 shadow-lg shadow-blue-600/30 hover:shadow-blue-500/50 hover:-translate-y-0.5">
            View Research
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href={`${base}/contact`}
            class="inline-flex items-center gap-2 px-5 py-2.5 border border-slate-700 hover:border-blue-500/60 text-slate-300 hover:text-white rounded-lg font-semibold text-sm transition-all duration-200 hover:bg-blue-500/10 hover:-translate-y-0.5">
            Contact Me
          </a>
        </div>

        <!-- Socials -->
        <div class="flex items-center gap-5 opacity-0 animate-fade-up" style="animation-delay: 0.6s; animation-fill-mode: forwards;">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}
              class="text-slate-500 hover:text-blue-400 transition-colors duration-200"
              set:html={s.icon}/>
          ))}
        </div>
      </div>

      <!-- Right: Avatar with orbiting cards -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div id="orbit-system" class="relative opacity-0 animate-fade-up flex items-center justify-center"
          style="width:420px;height:420px;animation-delay:0.3s;animation-fill-mode:forwards;">

          <!-- Orbit ring tracks -->
          <div class="absolute rounded-full border border-blue-500/10 border-dashed pointer-events-none"
            style="width:360px;height:360px;"></div>
          <div class="absolute rounded-full border border-indigo-500/8 pointer-events-none"
            style="width:300px;height:300px;"></div>

          <!-- Avatar centered -->
          <div class="relative z-10 flex-shrink-0">
            <div class="absolute -inset-4 rounded-full bg-gradient-to-br from-blue-600/20 to-indigo-600/10 blur-2xl"></div>
            <div class="relative p-[3px] rounded-full bg-gradient-to-br from-blue-400 via-blue-600 to-indigo-700 shadow-2xl shadow-blue-500/40 animate-float">
              <div class="p-[3px] rounded-full bg-[#020617]">
                <img
                  src={`${import.meta.env.BASE_URL}/avatar.jpg`}
                  alt="Duong Ngoc Vu"
                  class="w-44 h-44 sm:w-48 sm:h-48 rounded-full object-cover object-top"
                />
              </div>
            </div>
          </div>

          <!-- Orbiting cards (positioned by JS) -->
          <div class="orbit-card absolute z-20 bg-[#0a1628]/90 border border-indigo-500/30 rounded-xl px-3 py-2 shadow-xl backdrop-blur-sm pointer-events-none"
            data-orbit-speed="0.4">
            <p class="text-xs text-slate-500 leading-none">Academic</p>
            <p class="text-sm font-bold font-mono text-indigo-300 leading-tight mt-0.5">GPA 3.7</p>
            <p class="text-xs text-slate-600">/ 4.0</p>
          </div>

          <div class="orbit-card absolute z-20 bg-[#0a1628]/90 border border-blue-500/30 rounded-xl px-3 py-2 shadow-xl backdrop-blur-sm pointer-events-none"
            data-orbit-speed="0.4">
            <p class="text-xs text-slate-500 leading-none">Published</p>
            <p class="text-sm font-bold font-mono text-blue-300 leading-tight mt-0.5">2 Papers</p>
            <p class="text-xs text-slate-600">CITA 2026</p>
          </div>

          <div class="orbit-card absolute z-20 bg-[#0a1628]/90 border border-violet-500/30 rounded-xl px-3 py-2 shadow-xl backdrop-blur-sm pointer-events-none"
            data-orbit-speed="0.4">
            <p class="text-xs text-slate-500 leading-none">Conference</p>
            <p class="text-sm font-bold text-violet-300 leading-tight mt-0.5">Reviewer</p>
            <p class="text-xs text-slate-600">×2 venues</p>
          </div>

          <div class="orbit-card absolute z-20 bg-[#0a1628]/90 border border-slate-600/40 rounded-xl px-3 py-2 shadow-xl backdrop-blur-sm pointer-events-none"
            data-orbit-speed="0.4">
            <div class="flex items-center gap-2">
              <div class="w-5 h-5 rounded-md bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-white leading-none">AI Research</p>
                <p class="text-xs text-slate-500 leading-none mt-0.5">NEU · 2024–</p>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30 animate-bounce" aria-hidden="true">
      <span class="text-xs text-slate-500 tracking-widest uppercase">Scroll</span>
      <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  const system = document.getElementById('orbit-system');
  if (!system) return;

  const cards = Array.from(system.querySelectorAll('.orbit-card'));
  const N = cards.length;
  const RADIUS = 168;
  const PERIOD = 18000; // ms for full orbit

  // Initialize angle offsets so cards are evenly spaced
  const offsets = cards.map((_, i) => (i / N) * Math.PI * 2);

  let rafId;
  function animate(ts) {
    const t = ts / PERIOD * Math.PI * 2;
    cards.forEach((card, i) => {
      const angle = t + offsets[i];
      const x = Math.cos(angle) * RADIUS;
      const y = Math.sin(angle) * RADIUS;
      card.style.left = '50%';
      card.style.top  = '50%';
      card.style.transform = `translate(calc(${x}px - 50%), calc(${y}px - 50%))`;
    });
    rafId = requestAnimationFrame(animate);
  }

  rafId = requestAnimationFrame(animate);
})();
</script>
